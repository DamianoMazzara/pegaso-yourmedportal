# Copia questo file come `.env` nella root del monorepo (API, Drizzle e web leggono solo da lì).
# Host/porta/credenziali = dove gira *il tuo* MySQL (container separato, installazione locale, servizio su Dokploy, ecc.; non proviene dal docker-compose del repo).
DATABASE_URL=mysql://root:root@127.0.0.1:3306/yourmedportal
JWT_SECRET=change-me-in-dev-only-min-32-chars-long!!
API_PORT=3001
PUBLIC_API_URL=http://localhost:3001
