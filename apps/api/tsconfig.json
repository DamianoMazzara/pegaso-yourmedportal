{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"outDir": "dist",
	"rootDir": "src",
	"strict": true,
	"skipLibCheck": true,
	"esModuleInterop": true,
	"resolveJsonModule": true,
	"declaration": true,
	"noEmit": false,
	"outDir": "dist"
	},
	"include": ["src/**/*.ts"]
}
