{
	"name": "api",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/server.ts",
		"build": "tsc",
		"start": "node dist/server.js",
		"test": "node --import tsx --test --test-force-exit test/api.integration.test.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "node --env-file=../../.env ../../node_modules/drizzle-kit/bin.cjs migrate",
		"db:push": "node --env-file=../../.env ../../node_modules/drizzle-kit/bin.cjs push",
		"db:reset": "node --import tsx/esm scripts/reset-db.ts"
	},
	"dependencies": {
		"@hono/node-server": "^1.13.8",
		"@hono/swagger-ui": "^0.6.1",
		"@hono/zod-openapi": "^0.19.10",
		"bcryptjs": "^2.4.3",
		"dotenv": "^16.4.7",
		"drizzle-kit": "^0.30.4",
		"drizzle-orm": "^0.39.3",
		"hono": "^4.7.4",
		"jose": "^5.10.0",
		"mysql2": "^3.12.0",
		"nanoid": "^5.1.0",
		"tsx": "^4.19.3",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@types/bcryptjs": "^2.4.6",
		"@types/node": "^22.13.5",
		"typescript": "^5.9.3"
	}
}
